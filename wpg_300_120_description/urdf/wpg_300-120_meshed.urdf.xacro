<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
       name="wsg_300_120">

  <!-- Main gripper macro -->
  <xacro:macro name="wsg_300_120_xacro" params="name parent *origin">

    <!-- Base attachment -->
    <joint name="${name}_mount_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${name}_base_link"/>
    </joint>

    <!-- Base link -->
    <link name="${name}_base_link">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" ixy="0" ixz="0"
                 iyy="0.001" iyz="0"
                 izz="0.001"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/base.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/base.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- Left finger joint -->
    <joint name="${name}_finger_joint" type="prismatic">
      <limit lower="0" upper="0.06" effort="5" velocity="0.05"/>
      <origin xyz="0.042 0.0185 0.069" rpy="1.5708 0 -1.5708"/>
      <parent link="${name}_base_link"/>
      <child link="${name}_left_finger_link"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- Left finger -->
    <link name="${name}_left_finger_link">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0001"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/left_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/left_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- Right finger joint (mimics left finger) -->
    <joint name="${name}_right_finger_joint" type="prismatic">
      <mimic joint="${name}_finger_joint" multiplier="-1.0"/>
      <limit lower="-0.06" upper="0" effort="5" velocity="0.05"/>
      <origin xyz="-0.042 -0.0185 0.069" rpy="1.5708 0 -1.5708"/>
      <parent link="${name}_base_link"/>
      <child link="${name}_right_finger_link"/>
      <axis xyz="0 0 1"/>
    </joint>

    <!-- Right finger -->
    <link name="${name}_right_finger_link">
      <inertial>
        <mass value="0.1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0001"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/right_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://wpg_300_120_description/meshes/right_finger.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- Tool frame -->
    <link name="${name}_tool_frame"/>
    <joint name="${name}_tool_frame_joint" type="fixed">
      <origin xyz="0 0 0.13" rpy="0 0 0"/>
      <parent link="${name}_base_link"/>
      <child link="${name}_tool_frame"/>
    </joint>

  </xacro:macro>

</robot>
